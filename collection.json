  "item": [
    {
      "name": "Auth - Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const userSchema = {\r",
              "    \"type\": \"object\",\r",
              "    \"required\": [\"id\", \"username\", \"email\", \"firstName\", \"lastName\", \"gender\", \"image\", \"accessToken\", \"refreshToken\"],\r",
              "    \"properties\": {\r",
              "        \"id\": { \r",
              "            \"type\": \"integer\",\r",
              "            \"minimum\": 1,\r",
              "        },\r",
              "        \"username\": { \"type\": \"string\" },\r",
              "        \"email\": { \r",
              "            \"type\": \"string\", \r",
              "            \"format\": \"email\"\r",
              "        },\r",
              "        \"firstName\": { \"type\": \"string\" },\r",
              "        \"lastName\": { \"type\": \"string\" },\r",
              "        \"gender\": { \r",
              "            \"type\": \"string\",\r",
              "            \"enum\": [\"male\", \"female\"]\r",
              "        },\r",
              "        \"image\": { \r",
              "            \"type\": \"string\", \r",
              "            \"format\": \"uri\"\r",
              "        },\r",
              "        \"accessToken\": { \"type\": \"string\" },\r",
              "        \"refreshToken\": { \"type\": \"string\" }\r",
              "    }\r",
              "};\r",
              "\r",
              "pm.test(\"Статус ответа 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Данные ответа - корректны\", function () {\r",
              "    pm.response.to.have.jsonSchema(userSchema);\r",
              "});\r",
              "\r",
              "//Сохраняем данные\r",
              "if (pm.response.code === 200) {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.environment.set(\"token\", jsonData.accessToken);\r",
              "    pm.environment.set(\"userId\", jsonData.id);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"michaelw\",\r\n    \"password\": \"michaelwpass\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BASE_URL}}/auth/login",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
